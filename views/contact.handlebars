<section id="three" class="wrapper style1 fade-up">
  <div class="inner">
    <h2>{{title}}</h2>
    <p>You didn't expect this form to actually work did you? This is just a demo app :)</p>
    <div class="split style1">
      <section>
        <form method="post" action="#">
          <div class="fields">
            <div class="field half">
              <label for="name">Name</label>
              <input type="text" name="name" id="name" />
            </div>
            <div class="field half">
              <label for="email">Email</label>
              <input type="text" name="email" id="email" />
            </div>
            <div class="field">
              <label for="message">Message</label>
              <textarea name="message" id="message" rows="5"></textarea>
            </div>
          </div>
          <ul class="actions">
            <li><a href="" class="button submit">Send Message</a></li>
          </ul>
        </form>
      </section>
      <section>
        <ul class="contact">
          <li>
            <h3>Address</h3>
            <span>Department of Statistics<br />
            University of Colombo<br />
            Sri Lanka</span>
          </li>
          <li>
            <h3>Email</h3>
            <a href="#">dst@stat.cmb.ac.lk</a>
          </li>
          <li>
            <h3>Phone</h3>
            <span>+94 011-259 0111</span>
          </li>
          <li>
            <h3>Social</h3>
            <ul class="icons">
              <li><a href="https://web.facebook.com/statuoc/?_rdc=1&_rdr#" class="fa-facebook"><span class="label">Facebook</span></a></li>
              <li><a href="https://lk.linkedin.com/in/department-of-statistics-university-of-colombo-08b100333" class="fa-linkedin"><span class="label">LinkedIn</span></a></li>
            </ul>
          </li>
        </ul>
      </section>
    </div>
  </div>
</section>